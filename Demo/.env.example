# -----------------------------
# Smart Drainage Communication Layer
# Copy to `.env` and load securely.
# Do not commit real credentials or certificates.
# -----------------------------

# Real MQTT-over-TLS broker settings
# Use any managed broker (for example HiveMQ Cloud / EMQX Cloud / your campus broker).
MQTT_HOST=
MQTT_PORT=8883
MQTT_BRIDGE_USERNAME=your-bridge-username
MQTT_BRIDGE_PASSWORD=replace-with-strong-bridge-password
MQTT_EDGE_USERNAME=your-edge-username
MQTT_EDGE_PASSWORD=replace-with-strong-edge-password
# Leave blank for brokers signed by public CAs; set a path only for self-signed certs.
MQTT_CA_CERT=
MQTT_CLIENT_CERT=
MQTT_CLIENT_KEY=
MQTT_CLIENT_ID=smart-drainage-cloud-bridge
MQTT_TLS_INSECURE=false
CITY_NAMESPACE=smart-city
ENABLE_DEMO_SIMULATOR=false
FORCE_HTTPS=false
CORS_ALLOW_ORIGINS=http://localhost:5173

# Optional backward-compatible shared credentials
MQTT_USERNAME=
MQTT_PASSWORD=

# Dashboard WebSocket endpoint
VITE_TELEMETRY_WS_URL=ws://localhost:8000/ws/telemetry

# Edge gateway settings
EDGE_GATEWAY_ID=rpi-gateway-north-01
EDGE_GATEWAY_NODE_IDS=S-14,S-08,S-22,S-03
# Use HTTPS behind a reverse proxy in production; HTTP is fine for local testing.
EDGE_ALERT_API_URL=http://127.0.0.1:8000/api/v1/edge-alerts
TELEMETRY_DELTA_MM=25
TELEMETRY_DELTA_PCT=5
HEARTBEAT_SECONDS=60
PUBLISH_INTERVAL_SECONDS=5
MQTT_INITIAL_BACKOFF_SECONDS=1
MQTT_MAX_BACKOFF_SECONDS=32

# Layer 2 edge runtime settings
EDGE_NODE_ID=S-22
WATER_LEVEL_ADC_PIN=
WATER_LEVEL_SENSOR_MAX_MM=1200
WATER_LEVEL_THRESHOLD_MM=780
WATER_LEVEL_RESET_MM=640
MOVING_AVERAGE_WINDOW=5
SENSOR_SAMPLE_SECONDS=0.5
TELEMETRY_HOLDOFF_SECONDS=15
VALVE_GPIO_PIN=17
VALVE_ACTIVE_HIGH=true
USE_MOCK_GPIO=true
CAMERA_SOURCE=0
CAMERA_FRAME_WIDTH=640
CAMERA_FRAME_HEIGHT=480
CV_INFERENCE_INTERVAL_SECONDS=1.0
CV_CONFIDENCE_THRESHOLD=0.55
BLOCKAGE_REFRESH_SECONDS=20
TFLITE_MODEL_PATH=./edge/models/waste_yolov5n_int8.tflite
LABELS_PATH=./edge/models/waste_labels.txt
EDGE_QUEUE_PATH=./edge/data/offline_queue.jsonl
EDGE_RUN_SECONDS=0
